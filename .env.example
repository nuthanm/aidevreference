# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# PostgreSQL connection string (Neon recommended)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# SMTP mail delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM="AI Dev Reference <noreply@your-domain.com>"
MAIL_TO=admin@your-domain.com

# Cloudflare Turnstile (https://dash.cloudflare.com/)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key

# Admin API key for catalog sync and manual broadcast
ADMIN_BROADCAST_KEY=replace_with_secure_random_key

# Cron API key for scheduled auto-broadcast
CRON_BROADCAST_KEY=replace_with_secure_random_key

# Optional: Upstash Redis REST API for shared rate limiting across serverless instances
# https://upstash.com/docs/redis/overall/getstarted
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
